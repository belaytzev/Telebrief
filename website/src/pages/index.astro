---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImage from '../../public/logo.webp';
---

<Layout title="Telebrief - AI-Powered Telegram Digest Generator">

  <!-- Navigation -->
  <nav class="nav" aria-label="Main navigation">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <Image src={logoImage} alt="Telebrief" class="nav-logo" width={28} height={28} loading="eager" />
          <span>telebrief</span>
        </a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation menu" />
        <label for="nav-toggle" class="nav-hamburger" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </label>
        <div class="nav-links">
          <a href="#how-it-works" class="nav-link">How It Works</a>
          <a href="#features" class="nav-link">Features</a>
          <a href="https://github.com/belaytzev/Telebrief" class="nav-cta" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main>

    <!-- Hero -->
    <section class="hero" aria-labelledby="hero-title">
      <!-- Floating particles -->
      <div class="hero-particles" aria-hidden="true">
        <span class="particle p1"></span>
        <span class="particle p2"></span>
        <span class="particle p3"></span>
        <span class="particle p4"></span>
        <span class="particle p5"></span>
      </div>
      <div class="container">
        <div class="claude-badge">
          <span class="badge-dot" aria-hidden="true"></span>
          Powered by Claude Code
        </div>
        <h1 class="hero-title" id="hero-title">
          AI digest bot<br/>
          <span class="accent">for Telegram</span>
        </h1>
        <p class="hero-desc">
          Telebrief collects messages from your Telegram channels,
          generates AI-powered summaries grouped by channel or topic,
          and delivers polished daily digests directly to your account.
        </p>
        <div class="hero-actions">
          <a href="https://github.com/belaytzev/Telebrief?tab=readme-ov-file#-prerequisites" class="btn-primary" target="_blank" rel="noopener noreferrer">
            Get started →
          </a>
          <a href="#how-it-works" class="btn-ghost">
            How it works
          </a>
        </div>
        <div class="hero-stats" aria-label="Key statistics">
          <div class="stat-item">
            <span class="stat-num">$0</span>
            <span class="stat-label">free with Ollama</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-num">2</span>
            <span class="stat-label">digest modes</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-num">3</span>
            <span class="stat-label">AI providers</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat-item">
            <span class="stat-num">Any</span>
            <span class="stat-label">output language</span>
          </div>
        </div>
      </div>
    </section>

    <div class="rule" aria-hidden="true"></div>

    <!-- How It Works -->
    <section id="how-it-works" class="section" aria-labelledby="how-it-works-title">
      <div class="container">
        <p class="eyebrow">workflow</p>
        <h2 id="how-it-works-title">How Telebrief Works</h2>
        <p class="section-desc">Three automated phases take your channels from raw messages to a polished digest</p>

        <div class="phases">
          <div class="phase">
            <div class="phase-num" aria-hidden="true">1</div>
            <div class="phase-body">
              <h3>Collect Messages</h3>
              <p>Telebrief connects to your Telegram channels via Telethon and pulls all messages from the last 24 hours, including content from private channels you're a member of.</p>
              <div class="tag-row">
                <span class="tag">telethon</span>
                <span class="tag">user API</span>
                <span class="tag">private channels</span>
                <span class="tag">24h window</span>
              </div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-num" aria-hidden="true">2</div>
            <div class="phase-body">
              <h3>AI Summarization & Classification</h3>
              <p>Your chosen AI provider analyzes each channel's content, produces concise summaries, and can classify messages into topic groups like News, Events, or Sport — all in your configured output language.</p>
              <div class="tag-row">
                <span class="tag tag-a">OpenAI</span>
                <span class="tag tag-a">Anthropic</span>
                <span class="tag tag-a">Ollama</span>
                <span class="tag">multi-language</span>
                <span class="tag">topic classification</span>
              </div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-num" aria-hidden="true">3</div>
            <div class="phase-body">
              <h3>Format & Deliver</h3>
              <p>A beautifully formatted Markdown digest with clickable channel links and inline navigation buttons is sent directly to your Telegram via bot, on your schedule or on demand.</p>
              <div class="tag-row">
                <span class="tag">markdown</span>
                <span class="tag">channel links</span>
                <span class="tag">scheduled</span>
                <span class="tag">on-demand</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="rule" aria-hidden="true"></div>

    <!-- Bot Commands -->
    <section class="section" aria-labelledby="commands-title">
      <div class="container">
        <p class="eyebrow">bot interface</p>
        <h2 id="commands-title">Available Commands</h2>
        <p class="section-desc">Control Telebrief directly from Telegram with built-in bot commands</p>

        <div class="terminal" role="region" aria-label="Bot command reference">
          <div class="terminal-header" aria-hidden="true">
            <span class="tdot tdot-r"></span>
            <span class="tdot tdot-y"></span>
            <span class="tdot tdot-g"></span>
            <span class="terminal-title">telebrief bot</span>
          </div>
          <div class="terminal-body">
            <div class="cmd-line">
              <span class="cmd-prompt" aria-hidden="true">$</span>
              <span class="cmd-name">/start</span>
              <span class="cmd-desc">— Show welcome message and available commands</span>
            </div>
            <div class="cmd-line">
              <span class="cmd-prompt" aria-hidden="true">$</span>
              <span class="cmd-name">/digest</span>
              <span class="cmd-desc">— Generate digest using configured mode (channel or topic)</span>
            </div>
            <div class="cmd-line">
              <span class="cmd-prompt" aria-hidden="true">$</span>
              <span class="cmd-name">/status</span>
              <span class="cmd-desc">— View configuration and next scheduled run</span>
            </div>
            <div class="cmd-line">
              <span class="cmd-prompt" aria-hidden="true">$</span>
              <span class="cmd-name">/cleanup</span>
              <span class="cmd-desc">— Delete old digest messages from chat</span>
            </div>
            <div class="cmd-line">
              <span class="cmd-prompt" aria-hidden="true">$</span>
              <span class="cmd-name">/help</span>
              <span class="cmd-desc">— Show all commands and usage guide</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="rule" aria-hidden="true"></div>

    <!-- Features -->
    <section id="features" class="section" aria-labelledby="features-title">
      <div class="container">
        <p class="eyebrow">capabilities</p>
        <h2 id="features-title">Powerful Features</h2>
        <p class="section-desc">Everything you need to stay informed without information overload</p>

        <div class="bento-grid">
          <div class="bento-card bento-wide">
            <div class="feat-label">modes</div>
            <h3>Digest Modes</h3>
            <p>Group your digest by channel (default) or by AI-detected topics. Define custom topic groups like News, Events, or Sport — the AI classifies each message automatically.</p>
            <div class="mode-pills" aria-hidden="true">
              <span class="mode-pill mode-active">Channel Mode</span>
              <span class="mode-pill">Topic Mode</span>
            </div>
          </div>
          <div class="bento-card">
            <div class="feat-label">multi-provider</div>
            <h3>AI-Powered Summaries</h3>
            <p>Choose from OpenAI, Anthropic, or local Ollama to generate concise intelligent summaries. Switch providers with a single config change.</p>
          </div>
          <div class="bento-card">
            <div class="feat-label">i18n</div>
            <h3>Multi-Language Support</h3>
            <p>Collect messages in any language — English, Russian, Ukrainian, Chinese, and more. Output language is fully configurable.</p>
          </div>
          <div class="bento-card">
            <div class="feat-label">automation</div>
            <h3>Scheduled Delivery</h3>
            <p>Set a preferred delivery time and receive daily digests automatically. On-demand generation available via bot commands.</p>
          </div>
          <div class="bento-card">
            <div class="feat-label">access</div>
            <h3>Private Channels</h3>
            <p>Full support for private Telegram channels using Telethon user API. No restrictions on channel visibility or membership type.</p>
          </div>
          <div class="bento-card bento-wide">
            <div class="feat-label">cost</div>
            <h3>Ultra Affordable</h3>
            <p>Run completely free with local Ollama, or use cloud AI for ~$0.30 per month. Self-hosted, no subscription fees, no vendor lock-in.</p>
          </div>
          <div class="bento-card">
            <div class="feat-label">devops</div>
            <h3>Docker Ready</h3>
            <p>Complete Docker containerization with docker-compose. Deploy in minutes with a single command on any server or VPS.</p>
          </div>
          <div class="bento-card">
            <div class="feat-label">open source</div>
            <h3>MIT Licensed</h3>
            <p>Fully open source. Inspect the code, fork it, extend it. No black boxes. Your data stays on your own infrastructure.</p>
          </div>
        </div>
      </div>
    </section>

    <div class="rule" aria-hidden="true"></div>

    <!-- CTA -->
    <section class="section cta-section" aria-labelledby="cta-title">
      <div class="container">
        <h2 id="cta-title">Ready to get started?</h2>
        <p class="section-desc cta-desc">Deploy Telebrief in minutes and start receiving intelligent daily digests</p>
        <div class="cta-actions">
          <a href="https://github.com/belaytzev/Telebrief" class="btn-primary" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          <a href="https://github.com/belaytzev/Telebrief?tab=readme-ov-file#-docker-deployment" class="btn-ghost" target="_blank" rel="noopener noreferrer">
            Quick start guide →
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="footer" role="contentinfo">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <Image src={logoImage} alt="Telebrief" class="footer-logo" width={24} height={24} loading="lazy" />
          <span>telebrief</span>
        </div>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="https://github.com/belaytzev/Telebrief" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://github.com/belaytzev/Telebrief#readme" target="_blank" rel="noopener noreferrer">Docs</a>
          <a href="https://github.com/belaytzev/Telebrief/issues" target="_blank" rel="noopener noreferrer">Issues</a>
          <a href="https://t.me/telebrief" target="_blank" rel="noopener noreferrer">Telegram</a>
          <a href="https://github.com/belaytzev/Telebrief/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a>
        </nav>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 Telebrief — Open source under MIT License</span>
        <a href="https://claude.ai/claude-code" class="claude-credit" target="_blank" rel="noopener noreferrer" aria-label="Code written by Claude Code">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
          Powered by Claude Code
        </a>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ── Nav ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(20, 19, 16, 0.88);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.025em;
    color: var(--text);
    transition: color 0.2s;
  }
  .nav-brand:hover { color: var(--accent); }

  .nav-logo {
    width: 26px;
    height: 26px;
    border-radius: 6px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
  }
  .nav-link:hover { color: var(--text); }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.25s var(--ease-out-expo);
  }
  .nav-link:hover::after { width: 100%; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-on-accent);
    background: var(--accent);
    padding: 0.42rem 0.9rem;
    border-radius: 6px;
    transition: all 0.2s var(--ease-out-expo);
  }
  .nav-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  /* ── Mobile hamburger (CSS-only) ── */
  .nav-toggle { display: none; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    z-index: 10;
  }

  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 1px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .nav-toggle:checked ~ .nav-hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle:checked ~ .nav-hamburger span:nth-child(2) { opacity: 0; }
  .nav-toggle:checked ~ .nav-hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Shared ── */
  .rule { border-top: 1px solid var(--border); }

  .section { padding: 6rem 0; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .section-desc {
    font-size: 1.05rem;
    max-width: 520px;
    margin-top: 0.75rem;
    margin-bottom: 3.5rem;
    color: var(--text-muted);
  }

  h2 { margin-bottom: 0; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--accent);
    color: var(--text-on-accent);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.72rem 1.6rem;
    border-radius: 8px;
    transition: all 0.3s var(--ease-out-expo);
    position: relative;
    box-shadow: 0 1px 3px rgba(61, 165, 219, 0.2);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px -4px rgba(61, 165, 219, 0.35);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.72rem 1.6rem;
    border-radius: 8px;
    border: 1.5px solid var(--border-hover);
    transition: all 0.3s var(--ease-out-expo);
    background: transparent;
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  /* ── Hero ── */
  .hero {
    padding: 6.5rem 0 5.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-surface);
  }

  /* Dot grid pattern — "organized information" metaphor */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(61, 165, 219, 0.12) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Warm gradient wash */
  .hero::after {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 120%;
    height: 130%;
    background:
      radial-gradient(ellipse 50% 40% at 30% 20%, rgba(61, 165, 219, 0.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 35% at 70% 50%, rgba(123, 189, 224, 0.05) 0%, transparent 55%);
    animation: heroWash 15s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes heroWash {
    0% { transform: translate(0, 0); opacity: 0.6; }
    100% { transform: translate(2%, -1%); opacity: 1; }
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  /* Floating particles — subtle on light bg */
  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.18;
    animation: particleFloat 8s ease-in-out infinite;
  }

  .p1 { width: 4px; height: 4px; top: 18%; left: 12%; animation-delay: 0s; animation-duration: 7s; }
  .p2 { width: 3px; height: 3px; top: 72%; left: 85%; animation-delay: -2s; animation-duration: 9s; }
  .p3 { width: 5px; height: 5px; top: 35%; left: 68%; animation-delay: -4s; animation-duration: 11s; opacity: 0.12; }
  .p4 { width: 3px; height: 3px; top: 60%; left: 25%; animation-delay: -1s; animation-duration: 8s; }
  .p5 { width: 4px; height: 4px; top: 45%; left: 90%; animation-delay: -3s; animation-duration: 10s; opacity: 0.14; }

  @keyframes particleFloat {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-20px) translateX(8px); }
    50% { transform: translateY(-10px) translateX(-12px); }
    75% { transform: translateY(-24px) translateX(5px); }
  }

  .claude-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    border: 1px solid rgba(61, 165, 219, 0.25);
    background: rgba(61, 165, 219, 0.08);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin: 0 auto 2.25rem;
    letter-spacing: 0.02em;
    transition: all 0.3s var(--ease-out-expo);
  }

  .claude-badge:hover {
    background: rgba(61, 165, 219, 0.14);
    transform: translateY(-1px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px rgba(61, 165, 219, 0.5);
    animation: blink 2.2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  .hero-title {
    margin: 0 auto 1.5rem;
    max-width: 820px;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.02;
    color: var(--text);
    letter-spacing: -0.035em;
  }

