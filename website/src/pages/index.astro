</Layout>

<style>
  /* ── Nav ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(20, 19, 16, 0.88);
    backdrop-filter: blur(20px) saturate(1.3);
    -webkit-backdrop-filter: blur(20px) saturate(1.3);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.025em;
    color: var(--text);
    transition: color 0.2s;
  }
  .nav-brand:hover { color: var(--accent); }

  .nav-logo {
    width: 26px;
    height: 26px;
    border-radius: 6px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
    position: relative;
  }
  .nav-link:hover { color: var(--text); }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.25s var(--ease-out-expo);
  }
  .nav-link:hover::after { width: 100%; }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-on-accent);
    background: var(--accent);
    padding: 0.42rem 0.9rem;
    border-radius: 6px;
    transition: all 0.2s var(--ease-out-expo);
  }
  .nav-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  /* ── Mobile hamburger (CSS-only) ── */
  .nav-toggle { display: none; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    cursor: pointer;
    z-index: 10;
  }

  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 1px;
    transition: transform 0.25s, opacity 0.25s;
  }

  .nav-toggle:checked ~ .nav-hamburger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle:checked ~ .nav-hamburger span:nth-child(2) { opacity: 0; }
  .nav-toggle:checked ~ .nav-hamburger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Shared ── */
  .rule { border-top: 1px solid var(--border); }

  .section { padding: 6rem 0; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .section-desc {
    font-size: 1.05rem;
    max-width: 520px;
    margin-top: 0.75rem;
    margin-bottom: 3.5rem;
    color: var(--text-muted);
  }

  h2 { margin-bottom: 0; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--accent);
    color: var(--text-on-accent);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.72rem 1.6rem;
    border-radius: 8px;
    transition: all 0.3s var(--ease-out-expo);
    position: relative;
    box-shadow: 0 1px 3px rgba(61, 165, 219, 0.2);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px -4px rgba(61, 165, 219, 0.35);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.72rem 1.6rem;
    border-radius: 8px;
    border: 1.5px solid var(--border-hover);
    transition: all 0.3s var(--ease-out-expo);
    background: transparent;
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  /* ── Hero ── */
  .hero {
    padding: 6.5rem 0 5.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--bg-surface);
  }

  /* Dot grid pattern — "organized information" metaphor */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(61, 165, 219, 0.12) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Warm gradient wash */
  .hero::after {
    content: '';
    position: absolute;
    top: -30%;
    left: -10%;
    width: 120%;
    height: 130%;
    background:
      radial-gradient(ellipse 50% 40% at 30% 20%, rgba(61, 165, 219, 0.07) 0%, transparent 60%),
      radial-gradient(ellipse 40% 35% at 70% 50%, rgba(123, 189, 224, 0.05) 0%, transparent 55%);
    animation: heroWash 15s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes heroWash {
    0% { transform: translate(0, 0); opacity: 0.6; }
    100% { transform: translate(2%, -1%); opacity: 1; }
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  /* Floating particles — subtle on light bg */
  .hero-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.18;
    animation: particleFloat 8s ease-in-out infinite;
  }

  .p1 { width: 4px; height: 4px; top: 18%; left: 12%; animation-delay: 0s; animation-duration: 7s; }
  .p2 { width: 3px; height: 3px; top: 72%; left: 85%; animation-delay: -2s; animation-duration: 9s; }
  .p3 { width: 5px; height: 5px; top: 35%; left: 68%; animation-delay: -4s; animation-duration: 11s; opacity: 0.12; }
  .p4 { width: 3px; height: 3px; top: 60%; left: 25%; animation-delay: -1s; animation-duration: 8s; }
  .p5 { width: 4px; height: 4px; top: 45%; left: 90%; animation-delay: -3s; animation-duration: 10s; opacity: 0.14; }

  @keyframes particleFloat {
    0%, 100% { transform: translateY(0) translateX(0); }
    25% { transform: translateY(-20px) translateX(8px); }
    50% { transform: translateY(-10px) translateX(-12px); }
    75% { transform: translateY(-24px) translateX(5px); }
  }

  .claude-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    border: 1px solid rgba(61, 165, 219, 0.25);
    background: rgba(61, 165, 219, 0.08);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin: 0 auto 2.25rem;
    letter-spacing: 0.02em;
    transition: all 0.3s var(--ease-out-expo);
  }

  .claude-badge:hover {
    background: rgba(61, 165, 219, 0.14);
    transform: translateY(-1px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px rgba(61, 165, 219, 0.5);
    animation: blink 2.2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  .hero-title {
    margin: 0 auto 1.5rem;
    max-width: 820px;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.02;
    color: var(--text);
    letter-spacing: -0.035em;
  }

  .accent { color: var(--accent); }

  .hero-desc {
    font-size: 1.1rem;
    line-height: 1.76;
    max-width: 560px;
    margin: 0 auto 2.75rem;
    color: var(--text-muted);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    margin-bottom: 3.75rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    width: fit-content;
    margin: 0 auto;
    background: rgba(20, 19, 16, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.9rem 1.6rem;
  }

  .stat-num {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .stat-divider {
    width: 1px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Phases ── */
  .phases {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  }

  .phase {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 2rem;
    padding: 2.5rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.3s var(--ease-out-expo);
  }
  .phase:last-child { border-bottom: none; }
  .phase:hover { background: var(--bg-surface); }

  .phase-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    color: var(--text-faint);
    line-height: 1.1;
    padding-top: 0.1rem;
    letter-spacing: -0.04em;
    transition: color 0.3s var(--ease-out-expo);
  }

  .phase:hover .phase-num { color: var(--accent); }

  .phase-body h3 { margin-bottom: 0.6rem; }
  .phase-body p { margin-bottom: 1.1rem; }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.24rem 0.6rem;
    border-radius: 4px;
    background: var(--bg-raised);
    color: var(--text-muted);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }

  .tag-a {
    color: var(--accent);
    border-color: var(--accent-border);
    background: rgba(61, 165, 219, 0.08);
  }

  /* ── Terminal ── */
  .terminal {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    max-width: 680px;
    background: #0c0b09;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.35),
      0 1px 2px rgba(0, 0, 0, 0.25);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1rem;
    background: #111010;
    border-bottom: 1px solid var(--border);
  }

  .tdot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .tdot-r { background: var(--tdot-red); }
  .tdot-y { background: var(--tdot-yellow); }
  .tdot-g { background: var(--tdot-green); }

  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #5a5752;
    letter-spacing: 0.04em;
  }

  .terminal-body {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .cmd-line {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-mono);
  }

  .cmd-prompt {
    color: #5a5752;
    font-size: 0.875rem;
    width: 12px;
    flex-shrink: 0;
    user-select: none;
  }

  .cmd-name {
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    min-width: 88px;
  }

  .cmd-desc {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }

  .cmd-line:last-child .cmd-desc::after {
    content: '';
    display: inline-block;
    width: 7px;
    height: 14px;
    background: var(--accent);
    margin-left: 4px;
    vertical-align: text-bottom;
    animation: cursorBlink 1.1s step-end infinite;
    opacity: 0.7;
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 0; }
  }

  /* ── Example Output ── */
  .example-mode-toggle {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }

  .mode-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .mode-tabs {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1.1rem;
    justify-content: center;
  }

  .mode-tab {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0.45rem 1.05rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-raised);
    cursor: pointer;
    transition: all 0.25s var(--ease-out-expo);
    letter-spacing: 0.02em;
    user-select: none;
  }

  .mode-tab:hover {
    color: var(--text);
    border-color: var(--border-hover);
  }

  #mode-channel:checked ~ .mode-tabs label[for="mode-channel"],
  #mode-topic:checked ~ .mode-tabs label[for="mode-topic"] {
    color: var(--accent);
    border-color: var(--accent-border);
    background: rgba(61, 165, 219, 0.1);
  }

  .mode-radio:focus-visible ~ .mode-tabs label {
    outline: none;
  }
  #mode-channel:focus-visible ~ .mode-tabs label[for="mode-channel"],
  #mode-topic:focus-visible ~ .mode-tabs label[for="mode-topic"] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .example-bubble {
    border: 1px solid var(--border);
    border-top: 1px solid var(--accent-border);
    border-radius: 14px;
    background: var(--bg-surface);
    box-shadow:
      0 8px 28px rgba(0, 0, 0, 0.32),
      0 1px 2px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }

  .bubble-header {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.85rem 1.25rem;
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border);
  }

  .bubble-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .bubble-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.2;
  }

  .bubble-name {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text);
  }

  .bubble-time {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .bubble-body {
    display: none;
    padding: 1.6rem 1.85rem 1.85rem;
    animation: bubbleFade 0.3s var(--ease-out-expo);
  }

  #mode-channel:checked ~ .example-bubble .bubble-channel,
  #mode-topic:checked ~ .example-bubble .bubble-topic { display: block; }

  @keyframes bubbleFade {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .digest-h1 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--accent);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .digest-h2 {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 1.15rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .digest-p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .digest-list {
    list-style: none;
    padding: 0;
    margin-bottom: 0.4rem;
  }

  .digest-list li {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-muted);
    padding: 0.18rem 0;
  }

  .digest-list li strong {
    color: var(--text);
    font-weight: 600;
  }

  .digest-stats {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1.1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
  }

  .example-caption {
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 1.5rem;
  }

  .example-caption code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    background: rgba(61, 165, 219, 0.08);
    padding: 0.1rem 0.42rem;
    border-radius: 4px;
  }

  /* ── Bento Grid ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .bento-card {
    padding: 2rem;
    background: var(--bg);
    position: relative;
    transition: all 0.35s var(--ease-out-expo);
    overflow: hidden;
  }

  .bento-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, rgba(61, 165, 219, 0.05), transparent 60%);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out-expo);
    pointer-events: none;
  }

  .bento-card:hover::before { opacity: 1; }
  .bento-card:hover {
